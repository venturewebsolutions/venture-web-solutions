---
import { registry } from '@/integrations/images'
import {
  getSizes,
  getWidths,
  type ImageSizes,
  type ImageWidths,
} from '@/lib/images'
import type { HTMLAttributes } from 'astro/types'
import { getImage } from 'astro:assets'

type Props = Omit<HTMLAttributes<'source'>, 'src' | 'sizes'> & {
  src: string | ImageMetadata | Promise<{ default: ImageMetadata }>
  widths: ImageWidths
  sizes: ImageSizes
}

const { widths: _, sizes: __, src, ...props } = Astro.props

if (typeof src !== 'string') {
  const image = src instanceof Promise ? (await src).default : src
  registry.registerImage(image, {
    maxRenderWidth: Astro.props.widths.max,
  })
}

const widths = getWidths(Astro.props.widths)
const sizes = getSizes(Astro.props.sizes, Astro.props.widths)

const image = await getImage({
  src,
  widths,
  sizes,
})
---

<source srcset={image.srcSet.attribute} sizes={sizes} {...props} />
