---
import Schema from '@/components/headless/Schema.astro'
import CallToAction from '@/components/sections/CallToAction.astro'
import ContactUsHero from '@/components/sections/ContactUsHero.astro'
import CTAMarquee from '@/components/sections/CTAMarquee.astro'
import FAQ from '@/components/sections/FAQ.astro'
import Layout from '@/layouts/Layout.astro'
import { getFaqTopics } from '@/lib/collections'
import { url } from '@/lib/url'

const faqs = (await getFaqTopics())
  .flatMap((topic) => topic.data.faqs)
  .filter((faq) => faq.featured)
  .map((faq) => ({
    question: faq.question,
    answer: faq.answer,
  }))
---

<Layout
  title="Contact Our York Web Design Team | Venture Web Solutions"
  description="Have a question or ready to start a project? Contact the Venture Web Solutions team by email, phone, or WhatsApp — we typically respond within 24 hours."
>
  <Fragment slot="head">
    <Schema type="faq" faqs={faqs} />
  </Fragment>

  <ContactUsHero />
  <CallToAction />
  <CTAMarquee
    text="Let’s get started"
    href={url('/project-planner/')}
    groups={5}
  />
  <FAQ faqs={faqs} reversed />
</Layout>
