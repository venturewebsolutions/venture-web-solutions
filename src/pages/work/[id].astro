---
import CTAMarquee from '@/components/sections/CTAMarquee.astro'
import ProjectDetails from '@/components/sections/ProjectDetails.astro'
import ProjectHero from '@/components/sections/ProjectHero.astro'
import Testimonials from '@/components/sections/Testimonials.astro'
import Layout from '@/layouts/Layout.astro'
import { getTestimonials } from '@/lib/collections'
import { url } from '@/lib/url'
import { getCollection } from 'astro:content'

export async function getStaticPaths() {
  const work = await getCollection('work')

  return work.map((project) => ({
    params: { id: project.id },
    props: { project },
  }))
}

const { project } = Astro.props

const testimonials = await getTestimonials((t) => t.id !== project.id)
---

<Layout title={`${project.data.client} | Venture Web Solutions`} description="">
  <ProjectHero project={project} />
  {project.data.sections.map((section) => <ProjectDetails section={section} />)}
  <CTAMarquee groups={3} href={url('/work/')} text="View all projects" />
  <Testimonials testimonials={testimonials} />
</Layout>
