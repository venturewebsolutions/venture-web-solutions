---
import Heading from '@/components/headless/Heading.astro'
import Badge from '@/components/ui/Badge.astro'
import Button, { type ButtonVariant } from '@/components/ui/Button.astro'
import Divider from '@/components/ui/Divider.astro'
import { cn } from '@/lib/class-names'
import { url } from '@/lib/url'
import { Icon } from 'astro-icon/components'
import type { HTMLAttributes } from 'astro/types'
import Noise from './Noise.astro'

type Props = HTMLAttributes<'section'> & {
  heading: {
    text: string
    level: number
  }
  subheading: string | null
  price: {
    value: number
    monthly: boolean
    subtext: string | null
  }
  summary: string
  features: {
    description: string
    included: boolean
  }[]
  addOns: string[]
  popular: boolean
  background: {
    widths: number[]
    sizes: string
  }
  button: {
    variant: ButtonVariant
  }
}

const {
  heading,
  subheading,
  price,
  summary,
  features,
  addOns,
  background,
  button,
  popular,
  class: className,
  ...props
} = Astro.props
---

<section class:list={cn('card', className)} {...props}>
  <div class="card-background">
    {
      popular && (
        <>
          <div class="card-circle-1" />
          <div class="card-circle-2" />
          <div class="card-circle-3" />
        </>
      )
    }

    <Noise class="card-background-noise" />
  </div>

  <div class="card-header">
    <div class="card-header-header">
      <div class="card-badge-wrapper">
        {
          popular && (
            <Badge variant="primary" size="l">
              Popular
            </Badge>
          )
        }
      </div>

      <div class="card-heading">
        <Heading level={heading.level} class="card-title">
          {heading.text}
        </Heading>

        {subheading && <p>{subheading}</p>}
      </div>
    </div>

    <p>
      <span class="card-price-value">£{price.value}</span>
      {price.monthly && <span class="card-price-monthly">/month</span>}
      {price.subtext && <span class="card-price-subtext">{price.subtext}</span>}
    </p>

    <p class="card-summary">{summary}</p>
  </div>

  <Divider size="m" />

  <div class="card-content">
    <ul class="card-features">
      {
        features.map((feature) => (
          <li
            class:list={[
              'card-feature',
              !feature.included && 'card-feature-excluded',
            ]}
          >
            {feature.included ? (
              <Icon name="tick" class="card-feature-icon" />
            ) : (
              <Icon name="cross" class="card-feature-icon" />
            )}
            <span>{feature.description}</span>
          </li>
        ))
      }
    </ul>

    <Button variant={button.variant} href={url('/project-planner/')}>
      Let's get started
    </Button>
  </div>

  <Divider size="m" />

  <div class="card-footer">
    <p class="card-footer-heading">Add-ons:</p>

    <ul class="card-footer-list">
      {
        addOns.map((addOn) => (
          <li class="card-footer-list-item">
            <span>•</span>
            <span>{addOn}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style lang="scss">
  @use 'functions' as *;
  @use 'mixins' as *;

  .card {
    display: grid;
    justify-content: start;
    align-items: baseline;
    padding: var(--spacing-2xl);
    border: var(--border-width-s) solid var(--colour-primary);
    border-radius: var(--border-radius-xl);
    color: var(--colour-text-contrast);
    position: relative;
    overflow: hidden;
  }

  .card-header {
    grid-row: 1 / span 4;
    display: grid;
    grid-template-rows: subgrid;
    row-gap: var(--spacing-m);
    padding-bottom: var(--spacing-m);
  }

  .card-header-header {
    grid-row: 1 / span 2;
    display: grid;
    grid-template-rows: subgrid;
    row-gap: var(--spacing-m);
  }

  .card-title {
    @include font(h3);
    flex: 1;
  }

  .card-price-value {
    @include font(display-numeral-m);
    color: var(--colour-primary);
  }

  .card-price-frequency {
    @include font(h3);
  }

  .card-price-subtext {
    white-space: nowrap;
  }

  .card-content {
    grid-row: 6 / span 2;
    display: grid;
    grid-template-rows: subgrid;
    gap: var(--spacing-xl);
    padding-top: var(--spacing-m);
    padding-bottom: var(--spacing-xl);
  }

  .card-features {
    display: grid;
    gap: var(--spacing-xs);
  }

  .card-feature {
    display: flex;
    align-items: center;
    gap: var(--spacing-m);
  }

  .card-feature-icon {
    --size: #{rem(20px)};
  }

  .card-feature-excluded {
    opacity: 0.6;
  }

  .card-footer {
    display: grid;
    gap: var(--spacing-xs);
    padding-top: var(--spacing-m);
  }

  .card-footer-list {
    margin-left: var(--spacing-xs);
  }

  .card-footer-list-item {
    display: flex;
    align-items: baseline;
    gap: var(--spacing-s);
  }

  .card-background {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .card-background-noise {
    position: absolute;
    inset: 0;
  }

  .card-circle-1,
  .card-circle-2,
  .card-circle-3 {
    --inset: 5%;

    position: absolute;
    width: 46%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--colour-primary);
    filter: blur(111px);
    opacity: 0.75;

    animation-duration: 3s;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
    animation-direction: alternate;
  }

  .card-circle-1 {
    --travel: 200%;

    left: 0;
    top: 0;
    transform: translateY(calc(-100% + var(--inset)));
    animation-name: card-circle-1;
    animation-direction: alternate-reverse;
  }

  .card-circle-2 {
    --travel: 200%;

    left: 0;
    top: 30%;
    transform: translateX(calc(-100% + var(--inset)));
    animation-name: card-circle-2;
  }

  .card-circle-3 {
    --travel: 150%;

    left: 100%;
    top: 80%;
    transform: translateX(calc(-1 * var(--inset)));
    animation-name: card-circle-3;
  }

  @keyframes card-circle-1 {
    0% {
      transform: translateY(calc(-100% + var(--inset))) translateX(0%);
    }
    100% {
      transform: translateY(calc(-100% + var(--inset)))
        translateX(var(--travel));
    }
  }

  @keyframes card-circle-2 {
    0% {
      transform: translateX(calc(-100% + var(--inset))) translateY(0%);
    }
    100% {
      transform: translateX(calc(-100% + var(--inset)))
        translateY(var(--travel));
    }
  }

  @keyframes card-circle-3 {
    0% {
      transform: translateX(calc(-1 * var(--inset))) translateY(0%);
    }
    100% {
      transform: translateX(calc(-1 * var(--inset)))
        translateY(calc(-1 * var(--travel)));
    }
  }

  @media screen and (min-width: rem(1024px)) {
    .card-header-header {
      grid-template-columns: 1fr auto;
      column-gap: var(--spacing-m);
    }

    .card-heading {
      grid-row: 1 / span 2;
    }

    .card-badge-wrapper {
      order: 1;
      grid-row: 1 / span 2;
    }
  }
</style>
