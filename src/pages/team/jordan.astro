---
import BlogShowcaseCarousel from '@/components/sections/BlogShowcaseCarousel.astro'
import TeamMemberHero from '@/components/sections/TeamMemberHero.astro'
import TeamMemberProfile from '@/components/sections/TeamMemberProfile.astro'
import TeamMemberRole from '@/components/sections/TeamMemberRole.astro'
import Divider from '@/components/ui/Divider.astro'
import Layout from '@/layouts/Layout.astro'
import { getBlogPosts } from '@/lib/collections'

const roles = [
  {
    heading: 'Hand-coded builds',
    text: 'Hand-code every website from scratch.',
  },
  {
    heading: 'Clean code',
    text: 'Keep the code clean, organised, and built to last.',
  },
  {
    heading: 'Fast & accessible',
    text: 'Optimise speed, performance, and accessibility.',
  },
  {
    heading: 'Works everywhere',
    text: 'Make sure everything works perfectly across all devices.',
  },
]

const posts = (await getBlogPosts()).filter(
  (post) => post.data.author.name === 'Jordan',
)
---

<Layout
  title="Jordan | Venture Web Solutions"
  description="Meet Jordan, the developer at Venture Web Solutions — the one writing the code, optimising performance, and obsessing over the details."
>
  <TeamMemberHero
    eyebrow="Hi, I'm Jordan"
    name="Jordan"
    marquee={{
      groups: 2,
      images: [
        {
          src: import('@/assets/images/jordan-marquee-1.jpg'),
          alt: '',
        },
        {
          src: import('@/assets/images/jordan-marquee-2.jpg'),
          alt: '',
        },
        {
          src: import('@/assets/images/jordan-marquee-3.jpg'),
          alt: '',
        },
        {
          src: import('@/assets/images/jordan-marquee-4.jpg'),
          alt: '',
        },
        {
          src: import('@/assets/images/jordan-marquee-5.jpg'),
          alt: '',
        },
      ],
    }}
  >
    <Fragment slot="content-left">
      <p>
        The developer here at Venture Web Solutions — the one writing the code,
        optimising the performance, and obsessing over the tiny details that
        make a website feel fast, smooth, and reliable.
      </p>
    </Fragment>

    <Fragment slot="content-right">
      <p>
        I grew up in Yorkshire, studied physics, fell in love with software
        development, and eventually discovered that building websites sits
        perfectly at the intersection of logic, creativity, and problem-solving.
        These days, I spend my time turning design ideas into clean, efficient
        code and making sure your website loads as fast as possible.
      </p>

      <p>
        If you’re working with us, I’ll be the one you chat to about
        functionality, performance, and anything technical you’d like to
        understand (in plain English, of course).
      </p>
    </Fragment>
  </TeamMemberHero>

  <div class="container">
    <Divider size="s" />
  </div>

  <TeamMemberRole cards={roles} />

  <TeamMemberProfile />

  <BlogShowcaseCarousel posts={posts} />
</Layout>
