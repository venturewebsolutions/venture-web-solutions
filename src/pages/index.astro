---
import AboutUs from '@/components/sections/AboutUs.astro'
import BlogShowcaseGrid from '@/components/sections/BlogShowcaseGrid.astro'
import ContactUs from '@/components/sections/ContactUs.astro'
import CTAMarquee from '@/components/sections/CTAMarquee.astro'
import FAQ from '@/components/sections/FAQ.astro'
import Hero from '@/components/sections/Hero.astro'
import HowItWorks from '@/components/sections/HowItWorks.astro'
import OurWork from '@/components/sections/OurWork.astro'
import Performance from '@/components/sections/Performance.astro'
import Pricing from '@/components/sections/Pricing.astro'
import Testimonials from '@/components/sections/Testimonials.astro'
import WhatWeOffer from '@/components/sections/WhatWeOffer.astro'
import Layout from '@/layouts/Layout.astro'
import { getBlogPosts, getFaqTopics, getTestimonials } from '@/lib/collections'
import { url } from '@/lib/url'

const faqs = (await getFaqTopics())
  .flatMap((topic) => topic.data.faqs)
  .filter((faq) => faq.featured)
  .map((faq) => ({
    question: faq.question,
    answer: faq.answer,
  }))

const posts = (await getBlogPosts()).filter((posts) => posts.data.featured)

const testimonials = await getTestimonials()
---

<Layout title="Web Design York | Venture Web Solutions" description="" flush>
  <Hero class="hero" />
  <AboutUs reversed links />
  <WhatWeOffer />
  <Performance />
  <OurWork />
  <Testimonials testimonials={testimonials} />
  <HowItWorks />
  <Pricing />
  <FAQ faqs={faqs} link />
  <ContactUs reversed headingUnderline />
  <CTAMarquee
    text="Ready to work together?"
    href={url('/project-planner/')}
    groups={5}
  />
  <BlogShowcaseGrid posts={posts} />
</Layout>

<style lang="scss">
  @use 'functions' as *;
  @use 'mixins' as *;

  .hero {
    --padding-top: calc(
      var(--nav-height) + var(--nav-offset-top) - var(--spacing-l)
    );
  }
</style>
