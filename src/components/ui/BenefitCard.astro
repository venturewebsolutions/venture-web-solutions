---
import type { HTMLAttributes } from 'astro/types'
import Heading from '@/components/headless/Heading.astro'

type Props = {
  heading: string
  level?: number
  icon: (_props: HTMLAttributes<'svg'>) => any
}

const { heading, level = 3, icon: Icon } = Astro.props
---

<section class="card">
  <Icon class="card-icon" />
  <Heading level={level} class="card-heading h4">{heading}</Heading>
  <p class="card-paragraph"><slot /></p>
</section>

<style lang="scss">
  @use 'functions' as *;
  @use 'mixins' as *;

  .card {
    display: grid;
    gap: var(--spacing-m);
    justify-items: center;
    align-content: start;
    background-color: var(--colour-surface-100);
    padding: var(--spacing-6xl) var(--spacing-4xl);
    border-radius: var(--border-radius-m);
  }

  .card-icon {
    color: var(--colour-text-contrast);
    fill: var(--colour-surface-base);
  }

  .card-heading {
    text-align: center;
  }
</style>
