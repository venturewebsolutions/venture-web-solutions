---
import BlogPostCard from '@/components/ui/BlogPostCard.astro'
import Layout from '@/layouts/Layout.astro'
import { getBlogPosts } from '@/lib/collections'

const posts = await getBlogPosts()
---

<Layout title="Blog | Venture Web Solutions" description="">
  <section id="hero" class="container section">
    <header class="header">
      <h1 class="h2">Blog</h1>
      <p class="subheading">
        Here’s where we keep all our little secrets about web design,
        development, and related topics — tips, tricks, and things we wish we
        knew sooner!
      </p>
    </header>

    <div class="posts">
      {
        posts.map((post) => (
          <BlogPostCard
            post={post}
            level={2}
            thumbnailWidths={[216, 343, 432, 520, 708, 832, 1416]}
            thumbnailSizes="(min-width: 48rem) min(30vw, 416px), 100vw"
          />
        ))
      }
    </div>
  </section>
</Layout>

<style lang="scss">
  @use 'functions' as *;
  @use 'mixins' as *;

  .container {
    display: grid;
    gap: var(--spacing-2xl);
  }

  .header {
    display: grid;
    gap: var(--spacing-m);
  }

  .subheading {
    max-width: rem(648px);
  }

  .posts {
    display: grid;
    gap: var(--spacing-2xl);
  }

  @media screen and (min-width: rem(768px)) {
    .posts {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--spacing-2xl);
      align-items: start;
    }
  }
</style>
