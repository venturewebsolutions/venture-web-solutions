---
import FormField from '@/components/ui/FormField.astro'
import FormLabel from '@/components/ui/FormLabel.astro'
import type { AutocompleteValue } from '@/lib/types'

type Props = {
  id: string
  name: string
  type: astroHTML.JSX.HTMLInputTypeAttribute
  required?: boolean
  placeholder?: string
  autocomplete?: AutocompleteValue
  label: string
}

const { id, name, type, required, placeholder, autocomplete, label } =
  Astro.props
---

<FormField>
  <FormLabel for={id} required={required}>
    {label}
  </FormLabel>
  <input
    id={id}
    name={name}
    type={type}
    required={required}
    placeholder={placeholder}
    autocomplete={autocomplete}
    class="form-input"
  />
</FormField>
