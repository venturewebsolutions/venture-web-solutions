---
import PortfolioShowcase from '@/components/sections/PortfolioShowcase.astro'
import Testimonials from '@/components/sections/Testimonials.astro'
import Layout from '@/layouts/Layout.astro'
import { getTestimonials, getWork } from '@/lib/collections'

const projects = await getWork()
const testimonials = await getTestimonials()
---

<Layout
  title="Work (TODO)"
  description="A showcase of my projects and work experience."
>
  <PortfolioShowcase id="projects" projects={projects} />
  <Testimonials testimonials={testimonials} />
</Layout>
