---
import Button from '@/components/ui/Button/Button.astro'
import BlogPostGrid from '@/components/ui/BlogPostGrid/BlogPostGrid.astro'
import { url } from '@/lib/url'
import type { CollectionEntry } from 'astro:content'

type Props = {
  posts: CollectionEntry<'blog'>[]
}

const { posts } = Astro.props
---

<section id="blog" class="container section">
  <div class="intro">
    <header class="header">
      <p class="caption">Blog</p>
      <h2 class="title h2">What have we been writing about recently?</h2>
    </header>

    <Button variant="secondary-outline" href={url('/blog/')} arrow>
      Explore the Blog
    </Button>
  </div>

  <BlogPostGrid posts={posts} blogPostTitleTag="h3" />
</section>

<style lang="scss">
  @use 'functions' as *;
  @use 'mixins' as *;

  #blog {
    display: grid;
    gap: var(--spacing-4xl);
  }

  .intro {
    display: grid;
    gap: var(--spacing-xl);
    justify-items: start;
  }

  .title {
    max-width: rem(535px);
  }

  @media screen and (min-width: rem(1024px)) {
    .intro {
      grid-template-columns: 1fr auto;
      justify-content: space-between;
      align-items: end;
    }
  }
</style>
