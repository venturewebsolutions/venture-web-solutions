---
import FormField from '@/components/ui/FormField.astro'
import FormLabel from '@/components/ui/FormLabel.astro'
import type { AutocompleteValue } from '@/lib/types'

type Props = {
  id: string
  name: string
  required?: boolean
  placeholder?: string
  autocomplete?: AutocompleteValue
  label?: string
}

const { id, name, required, placeholder, autocomplete, label } = Astro.props
---

<FormField>
  {
    label && (
      <FormLabel for={id} required={required}>
        {label}
      </FormLabel>
    )
  }
  <textarea
    id={id}
    name={name}
    required={required}
    placeholder={placeholder}
    autocomplete={autocomplete}
    rows="3"
    class="form-input"></textarea>
</FormField>
