---
import BlogPostGrid from '@/components/ui/BlogPostGrid.astro'
import Layout from '@/layouts/Layout.astro'
import { getBlogPosts } from '@/lib/collections'

const posts = await getBlogPosts()
---

<Layout title="Blog (TODO)" description="TODO">
  <div class="container section">
    <header class="header">
      <h1 class="h2">Blog</h1>
      <p class="subheading">
        Here’s where we keep all our little secrets about web design,
        development, and related topics — tips, tricks, and things we wish we
        knew sooner!
      </p>
    </header>

    <BlogPostGrid posts={posts} blogPostHeadingLevel={2} />
  </div>
</Layout>

<style lang="scss">
  @use 'functions' as *;
  @use 'mixins' as *;

  .container {
    display: grid;
    gap: var(--spacing-2xl);
  }

  .header {
    display: grid;
    gap: var(--spacing-m);
  }

  .subheading {
    max-width: rem(648px);
  }
</style>
