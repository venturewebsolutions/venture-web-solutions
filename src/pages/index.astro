---
import AboutUs from '@/components/sections/home/AboutUs.astro'
import Blog from '@/components/sections/home/Blog.astro'
import Hero from '@/components/sections/home/Hero.astro'
import OurWork from '@/components/sections/home/OurWork.astro'
import Performance from '@/components/sections/home/Performance.astro'
import Pricing from '@/components/sections/home/Pricing.astro'
import WhatWeOffer from '@/components/sections/home/WhatWeOffer.astro'
import ContactUs from '@/components/sections/shared/ContactUs.astro'
import CTAMarquee from '@/components/sections/shared/CTAMarquee.astro'
import FAQ from '@/components/sections/shared/FAQ.astro'
import HowItWorks from '@/components/sections/shared/HowItWorks.astro'
import Testimonials from '@/components/sections/shared/Testimonials.astro'
import Layout from '@/layouts/Layout.astro'
import { getBlogPosts, getFaqTopics } from '@/lib/collections'
import { url } from '@/lib/url'

const faqs = (await getFaqTopics())
  .flatMap((topic) => topic.data.faqs)
  .filter((faq) => faq.featured)
  .map((faq) => ({
    question: faq.question,
    answer: faq.answer,
  }))

const posts = (await getBlogPosts())
  .filter((posts) => posts.data.featured)
  .map((post) => ({
    title: post.data.title,
    topic: post.data.topic,
    url: url(`/blog/posts/${post.id}/`),
    thumbnail: post.data.thumbnail,
    author: post.data.author,
    readTimeMinutes: post.data.readTimeMinutes,
  }))
---

<Layout
  title="Welcome to Venture Web Solutions"
  description="Your partner in digital success."
>
  <Hero />
  <AboutUs />
  <WhatWeOffer />
  <Performance />
  <OurWork />
  <Testimonials />
  <HowItWorks />
  <Pricing />
  <FAQ faqs={faqs} />
  <ContactUs reversed headingUnderline />
  <CTAMarquee
    id="ready-to-work-together"
    text="Ready to work together?"
    href={url('/project-planner/')}
    groups={5}
  />
  <Blog posts={posts} />
</Layout>
