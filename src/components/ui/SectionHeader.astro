---
import type { HTMLAttributes } from 'astro/types'
import Heading from '@/components/headless/Heading.astro'
import Eyebrow from '@/components/ui/Eyebrow.astro'
import { cn } from '@/lib/class-names'

type Props = HTMLAttributes<'header'> & {
  eyebrow: string
  level?: number
}

const { eyebrow, level = 2, class: className, ...props } = Astro.props
---

<header class:list={cn('header', className)} {...props}>
  <Eyebrow>{eyebrow}</Eyebrow>
  <Heading level={level} class="h2"><slot /></Heading>
</header>

<style lang="scss">
  @use 'functions' as *;
  @use 'mixins' as *;

  .header {
    display: grid;
    gap: var(--spacing-xs);
  }
</style>
