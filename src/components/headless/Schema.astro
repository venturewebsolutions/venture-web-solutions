---
type Props = {
  type: 'faq'
  faqs: {
    question: string
    answer: string
  }[]
}

const { faqs } = Astro.props

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
}
---

<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify(schema)}
/>
