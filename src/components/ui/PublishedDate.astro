---
import { Icon } from 'astro-icon/components'

type Props = {
  date: Date
}

const { date } = Astro.props

const formatted = date.toLocaleDateString('en-GB', {
  dateStyle: 'medium',
})
---

<div class="published-date">
  <Icon name="clock" class="icon" />
  <p>{formatted}</p>
</div>

<style lang="scss">
  @use 'functions' as *;
  @use 'mixins' as *;

  .published-date {
    display: flex;
    align-items: center;
    gap: var(--spacing-2xs);
  }

  .icon {
    --size: #{rem(16px)};
  }
</style>
