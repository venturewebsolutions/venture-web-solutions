    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"></path>
</svg>

<style lang="scss">
  @use 'functions' as *;
  @use 'mixins' as *;

  svg[data-animate] path {
    --length: 1020.6419677734375;

    stroke-dasharray: var(--length);
    stroke-dashoffset: var(--length);
    animation: draw 0.6s ease-in-out forwards 0.1s;
  }

  @keyframes draw {
    to {
      stroke-dashoffset: 0;
    }
  }
</style>
