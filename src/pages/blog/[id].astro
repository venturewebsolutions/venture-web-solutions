---
import BlogPostContent from '@/components/sections/BlogPostContent.astro'
import BlogPostHero from '@/components/sections/BlogPostHero.astro'
import BlogShowcaseCarousel from '@/components/sections/BlogShowcaseCarousel.astro'
import Layout from '@/layouts/Layout.astro'
import { getBlogPosts } from '@/lib/collections'
import take from 'lodash/take'

export async function getStaticPaths() {
  const posts = await getBlogPosts()

  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }))
}

const { post } = Astro.props

const posts = take(await getBlogPosts(), 6)
---

<Layout
  title={`${post.data.title} | Venture Web Solutions`}
  description={post.data.meta.description}
>
  <BlogPostHero post={post} />
  <BlogPostContent post={post} />
  <BlogShowcaseCarousel posts={posts} />
</Layout>
