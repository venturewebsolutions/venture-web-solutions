---
import { Image } from 'astro:assets'
import { url } from '@/lib/url'
import Eyebrow from '@/components/ui/Eyebrow.astro'
import type { HTMLAttributes } from 'astro/types'
import { cn } from '@/lib/class-names'

type Props = HTMLAttributes<'section'>

const { class: className, ...props } = Astro.props

const projects = [
  {
    id: 'maggi-maid',
    name: 'Maggi Maid',
    image: import('@/assets/images/maggi-maid-screenshot.png'),
  },
  {
    id: 'stefanos',
    name: "Stefano's Pizzeria",
    image: import('@/assets/images/stefanos-screenshot.png'),
  },
  {
    id: 'sos-party-rental',
    name: 'SOS Party Rental',
    image: import('@/assets/images/sos-party-rental-screenshot.png'),
  },
  {
    id: 'popletts',
    name: "Poplett's Dog Grooming",
    image: import('@/assets/images/popletts-screenshot.png'),
  },
  {
    id: 'md-loft-storage',
    name: 'MD Loft Storage',
    image: import('@/assets/images/md-loft-storage-screenshot.png'),
  },
]
---

<section
  class:list={cn('section container', className)}
  data-component="our-work"
  {...props}
>
  <div class="card">
    <div class="content-left">
      <Eyebrow as="h2">Our Work</Eyebrow>

      <div class="title-carousel">
        <div class="titles">
          {
            projects.map((project) => (
              <a
                href={url(`/work/${project.id}`)}
                class="title h2"
                data-project={project.id}
              >
                {project.name}
              </a>
            ))
          }
        </div>

        <div class="title-carousel-overlay"></div>
      </div>
    </div>

    <div class="image-carousel">
      <div class="images">
        {
          projects.map((project) => (
            <section class="image-card" data-project={project.id}>
              <a href={url(`/work/${project.id}`)} class="image-link">
                <Image
                  src={project.image}
                  alt={`${project.name} project screenshot`}
                  style={`--cursor-url: url(${url('/cursor.svg')});`}
                  class="image"
                  widths={[525, 708, 1030, 1416]}
                  sizes="(min-width: 48rem) min(40vw, 525px), 100vw"
                />
                <div class="image-footer">
                  <h3 class="h4">{project.name}</h3>
                </div>
              </a>
            </section>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use 'functions' as *;
  @use 'mixins' as *;

  .card {
    display: grid;
    gap: var(--spacing-xl);
  }

  .title-carousel {
    display: none;
  }

  .image-carousel {
    position: relative;
  }

  .images {
    display: grid;
    gap: var(--spacing-xl);
  }

  .image-card {
    border-radius: var(--border-radius-m);
    overflow: hidden;

    transition: filter var(--transition-duration-default)
      var(--transition-ease-default);

    &:hover,
    &.active {
      filter: blur(2px);
    }
  }

  .image-link {
    display: block;
  }

  .image {
    display: block;
    width: 100%;
    cursor:
      var(--cursor-url) 56.5 56.5,
      pointer;
  }

  .image-footer {
    padding: var(--spacing-xs) var(--spacing-m);
    background: var(--colour-surface-100);
  }

  @media screen and (min-width: rem(768px)) {
    .section {
      display: grid;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }

    .card {
      background: var(--colour-surface-100);
      border-radius: var(--border-radius-l);
      padding: var(--spacing-4xl);
      grid-template-columns: repeat(2, 1fr);
      gap: var(--spacing-4xl);
      overflow: hidden;
      min-height: 60svh;
    }

    .content-left {
      display: grid;
      align-content: space-between;
      gap: var(--spacing-5xl);
    }

    .title-carousel {
      display: block;
      position: relative;
    }

    .titles {
      display: grid;
      gap: var(--spacing-2xl);
      padding-block: 0.5em;
    }

    .title {
      transition: transform var(--transition-duration-default)
        var(--transition-ease-default);

      &:hover,
      &.active {
        transform: translateX(0.75rem);
      }
    }

    .title-carousel-overlay {
      @include font(h2);

      --spotlight-background: color-mix(
        in srgb,
        var(--colour-surface-100) 100%,
        transparent
      );
      --spotlight-foreground: color-mix(
        in srgb,
        var(--colour-surface-100) 20%,
        transparent
      );
      --spotlight-size: 20%;
      --spotlight-position: 10%;

      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        var(--spotlight-background) 0%,
        var(--spotlight-foreground)
          calc(var(--spotlight-position) - var(--spotlight-size) / 2),
        rgba(0, 0, 0, 0) var(--spotlight-position),
        var(--spotlight-foreground)
          calc(var(--spotlight-position) + var(--spotlight-size) / 2),
        var(--spotlight-background) 100%
      );
      pointer-events: none;
    }

    .images {
      position: absolute;
    }

    .image-footer {
      display: none;
    }
  }
</style>

<script>
  import { onImagesLoaded } from '@/lib/images'
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  window.addEventListener('load', () => {
    const mm = gsap.matchMedia()

    const root = document.querySelector('[data-component="our-work"]')!
    const imageCarousel = root.querySelector('.image-carousel')!
    const titleCarouselOverlay = root.querySelector('.title-carousel-overlay')!
    const imagesWrapper = root.querySelector('.images')!
    const imageCards = root.querySelectorAll<HTMLElement>('.image-card')
    const images = root.querySelectorAll<HTMLImageElement>('.image')

    onImagesLoaded(images, () => {
      mm.add('(min-width: 48rem)', () => {
        gsap
          .timeline({
            scrollTrigger: {
              trigger: root,
              start: 'top top',
              end: () => `+=${imageCarousel.scrollHeight}`,
              scrub: true,
              pin: true,
            },
          })
          .to(imagesWrapper, { bottom: 0, ease: 'none' }, 0)
          .to(titleCarouselOverlay, { '--spotlight-position': '90%' }, 0)
      })
    })

    for (const imageCard of imageCards) {
      const project = imageCard.dataset.project

      const title = root.querySelector(`.title[data-project="${project}"]`)!

      imageCard.addEventListener('mouseenter', () => {
        title.classList.add('active')
      })

      imageCard.addEventListener('mouseleave', () => {
        title.classList.remove('active')
      })

      title.addEventListener('mouseenter', () => {
        imageCard.classList.add('active')
      })

      title.addEventListener('mouseleave', () => {
        imageCard.classList.remove('active')
      })
    }
  })
</script>
