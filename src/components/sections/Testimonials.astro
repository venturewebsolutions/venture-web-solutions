---
import NavigationButton from '@/components/ui/NavigationButton.astro'
import SectionHeader from '@/components/ui/SectionHeader.astro'
import TestimonialCard from '@/components/ui/TestimonialCard.astro'
import { cn } from '@/lib/class-names'
import type { HTMLAttributes } from 'astro/types'
import type { CollectionEntry } from 'astro:content'

type Props = HTMLAttributes<'section'> & {
  testimonials: CollectionEntry<'testimonials'>[]
}

const { testimonials, class: className, ...props } = Astro.props
---

<section
  class:list={cn('section container', className)}
  data-component="testimonials"
  {...props}
>
  <SectionHeader eyebrow="Client testimonials">
    Voice of our happy clients
  </SectionHeader>

  <div class="swiper">
    <div class="swiper-wrapper">
      {
        testimonials.map((testimonial) => (
          <div class="swiper-slide">
            <TestimonialCard
              testimonial={testimonial}
              image={{
                widths: {
                  min: 265,
                  max: 552,
                  mobile: 378,
                  desktop: 385,
                },
                sizes: [
                  '(min-width: 90rem) 26rem',
                  '(min-width: 63rem) 33.33vw',
                  '(min-width: 37.5rem) 50vw',
                  '100vw',
                ],
              }}
            />
          </div>
        ))
      }
    </div>
  </div>

  <div class="navigation">
    <NavigationButton dir="left" class="swiper-button-prev" />
    <div class="swiper-pagination"></div>
    <NavigationButton dir="right" class="swiper-button-next" />
  </div>
</section>

<style lang="scss">
  @use 'functions' as *;
  @use 'mixins' as *;

  .section {
    display: grid;
    gap: var(--spacing-2xl);
  }

  .navigation {
    display: flex;
    justify-content: space-between;
  }
</style>

<script>
  import 'swiper/css'
  import Swiper from 'swiper/bundle'
  import { Navigation, Pagination } from 'swiper/modules'

  // Swiper
  window.addEventListener('load', () => {
    new Swiper('[data-component="testimonials"] .swiper', {
      modules: [Navigation, Pagination],

      slidesPerView: 1,
      spaceBetween: 32,

      breakpoints: {
        600: {
          slidesPerView: 2,
          spaceBetween: 24,
        },

        1024: {
          slidesPerView: 3,
          spaceBetween: 32,
        },
      },

      navigation: {
        nextEl: '[data-component="testimonials"] .swiper-button-next',
        prevEl: '[data-component="testimonials"] .swiper-button-prev',
      },

      pagination: {
        el: '[data-component="testimonials"] .swiper-pagination',
      },
    })
  })
</script>
