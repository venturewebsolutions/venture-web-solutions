---
import type { HTMLAttributes } from 'astro/types'
import { cn } from '../../lib/class-names'

type Props = HTMLAttributes<'button'>

const { class: className, ...props } = Astro.props
---

<button {...props} class:list={cn('disclosure-trigger', className)}>
  <slot />
</button>

<style lang="scss">
  @use 'functions' as *;
  @use 'mixins' as *;

  .disclosure-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    cursor: pointer;
  }
</style>
