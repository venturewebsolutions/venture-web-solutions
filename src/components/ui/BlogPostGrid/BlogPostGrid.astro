---
import { Image } from 'astro:assets'
import Badge from '@/components/ui/Badge/Badge.astro'
import Thumbnail from '@/components/ui/Thumbnail/Thumbnail.astro'
import ThumbnailCaption from '@/components/ui/Thumbnail/ThumbnailCaption.astro'
import { url } from '@/lib/url'
import type { HeadingTag } from '@/lib/types'
import type { CollectionEntry } from 'astro:content'

type Props = {
  posts: CollectionEntry<'blog'>[]
  blogPostTitleTag: HeadingTag
}

const { posts, blogPostTitleTag: BlogPostTitleTag } = Astro.props
---

<div class="posts">
  {
    posts.map((post) => (
      <section class="post">
        <Thumbnail>
          <a href={url(`/blog/${post.id}/`)} aria-label={post.data.title}>
            <Image
              src={post.data.thumbnail.image}
              alt={post.data.thumbnail.description}
              class="thumbnail-image"
              style={`--cursor-url: url(${url('/cursor.svg')});`}
              widths={[216, 343, 432, 520, 708, 832, 1416]}
              sizes="(min-width: 48rem) min(30vw, 416px), 100vw"
            />
          </a>

          <ThumbnailCaption
            position="bottom left"
            class="thumbnail-caption thumbnail-caption-bottom-left"
          >
            <Image
              src={post.data.author.avatar}
              alt={`${post.data.author.name} avatar`}
              class="avatar"
              widths={[43, 86]}
              sizes="43px"
            />
          </ThumbnailCaption>

          <ThumbnailCaption
            position="top right"
            class="thumbnail-caption thumbnail-caption-top-right"
          >
            <Badge variant="tertiary" size="s">
              {post.data.topic}
            </Badge>
          </ThumbnailCaption>
        </Thumbnail>

        <div class="post-summary">
          <p class="post-caption caption">
            {post.data.readTimeMinutes} mins read
          </p>
          <a href={`/blog/${post.id}/`}>
            <BlogPostTitleTag class="post-title">
              {post.data.summary}
            </BlogPostTitleTag>
          </a>
        </div>
      </section>
    ))
  }
</div>

<style lang="scss">
  @use 'functions' as *;
  @use 'mixins' as *;

  .posts {
    display: grid;
    gap: var(--spacing-2xl);
  }

  .post {
    display: grid;
    gap: var(--spacing-m);
  }

  .thumbnail-image {
    border-radius: var(--border-radius-m);
    width: 100%;
    aspect-ratio: 421/238;
    object-fit: cover;
    cursor:
      var(--cursor-url) 56.5 56.5,
      pointer;
  }

  .thumbnail-caption {
    --background-color: var(--colour-surface-base);
    --border-radius: var(--border-radius-s);
    --inverted-border-radius: var(--border-radius-m);
  }

  .thumbnail-caption-bottom-left {
    --padding: #{rem(10px)};
  }

  .thumbnail-caption-top-right {
    --padding: #{rem(8px)};
  }

  .avatar {
    width: rem(43px);
    height: rem(43px);
  }

  .post-summary {
    display: grid;
    gap: var(--spacing-xs);
  }

  .post-caption {
    @include font-body;
  }

  .post-summary {
    @include font-h4;
  }

  @media screen and (min-width: rem(768px)) {
    .posts {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--spacing-2xl);
      align-items: start;
    }
  }
</style>
