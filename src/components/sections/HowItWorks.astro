---
import NavigationButton from '@/components/ui/NavigationButton.astro'
import NumberCard from '@/components/ui/NumberCard.astro'
import SectionHeader from '@/components/ui/SectionHeader.astro'
import { cn } from '@/lib/class-names'
import type { HTMLAttributes } from 'astro/types'

type Props = HTMLAttributes<'section'> & {
  eyebrow?: string
  heading?: string
  subheading?: string
  steps?: {
    heading: string
    text: string
  }[]
}

const {
  eyebrow = 'Steps',
  heading = 'How it works',
  subheading = 'It’s simple (we promise)!',
  steps: _,
  class: className,
  ...props
} = Astro.props

const steps = Astro.props.steps ?? [
  {
    heading: 'Discovery & Planning',
    text: 'We’ll have a chat about your business, your goals with the website, and make sure we can help you achieve them. If everyone’s happy, we’ll send over a contract so we can get started!',
  },
  {
    heading: 'Design',
    text: 'We’ll work with you to design something that suits your tastes and your business needs. Don’t worry, we’ll even write the content for you. We’ll make sure you’re totally happy with the design before we start building the site, and if we can’t design something you like, we’ll even give you your money back and cancel the contract. How about that!',
  },
  {
    heading: 'Development & Launch',
    text: 'Finally, we’ll get to work on writing the code and building your site, line-by-line. When it’s done, we’ll show you a preview version and make sure you’re happy before putting it live for all the world to see!',
  },
  {
    heading: 'Celebrate',
    text: 'Congratulations, you’ve now got a professional website. Time to celebrate!',
  },
  {
    heading: 'Support',
    text: 'You haven’t seen the end of us yet. We’re always here when you need us. We pride ourselves on this, so please rest assured that you can always contact us for anything you need.',
  },
]
---

<section
  class:list={cn('section container', className)}
  data-component="how-it-works"
  {...props}
>
  <div class="intro">
    <SectionHeader eyebrow={eyebrow}>{heading}</SectionHeader>

    <p>{subheading}</p>
  </div>

  <div class="steps swiper">
    <div class="swiper-wrapper">
      {
        steps.map((step, i) => (
          <div class="swiper-slide">
            <NumberCard number={i + 1} heading={step.heading} level={3}>
              {step.text}
            </NumberCard>
          </div>
        ))
      }
    </div>
  </div>

  <div class="navigation">
    <NavigationButton dir="left" class="swiper-button-prev" />
    <NavigationButton dir="right" class="swiper-button-next" />
  </div>
</section>

<style lang="scss">
  @use 'functions' as *;
  @use 'mixins' as *;

  .section {
    display: grid;
    gap: var(--spacing-2xl);
    grid-template-areas:
      'intro'
      'steps'
      'navigation';
  }

  .intro {
    grid-area: intro;
    display: grid;
    gap: var(--spacing-m);
  }

  .steps {
    grid-area: steps;
  }

  .navigation {
    grid-area: navigation;
    display: flex;
    gap: var(--spacing-xl);
  }

  @media screen and (min-width: rem(1024px)) {
    .section {
      grid-template-columns: repeat(3, 1fr);
      grid-template-areas:
        'intro steps steps'
        'navigation steps steps';
    }

    .intro {
      align-self: start;
    }

    .navigation {
      align-self: end;
    }
  }
</style>

<script>
  import 'swiper/css'
  import Swiper from 'swiper/bundle'
  import { Navigation } from 'swiper/modules'

  window.addEventListener('load', () => {
    new Swiper('[data-component="how-it-works"] .swiper', {
      modules: [Navigation],

      slidesPerView: 1,
      spaceBetween: 32,

      breakpoints: {
        1024: {
          slidesPerView: 2,
          spaceBetween: 32,
        },
      },

      navigation: {
        nextEl: '[data-component="how-it-works"] .swiper-button-next',
        prevEl: '[data-component="how-it-works"] .swiper-button-prev',
      },
    })
  })
</script>
