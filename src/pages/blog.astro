---
import BlogHero from '@/components/sections/BlogHero.astro'
import Layout from '@/layouts/Layout.astro'
import { getBlogPosts } from '@/lib/collections'

const posts = await getBlogPosts()
---

<Layout
  title="Web Design Blog | Venture Web Solutions"
  description="Read practical web design, development, SEO, and performance tips for small businesses that want a faster, more professional website."
>
  <BlogHero posts={posts} />
</Layout>
