---
import Layout from '@/layouts/Layout.astro'
import ContactUs from '@/components/sections/ContactUs.astro'
import FAQ from '@/components/sections/FAQ.astro'
import PricingSection from '@/components/sections/Pricing.astro'
import Testimonials from '@/components/sections/Testimonials.astro'
import HowItWorks from '@/components/sections/HowItWorks.astro'
import { getFaqTopics } from '@/lib/collections'

const faqs = (await getFaqTopics())
  .flatMap((topic) => topic.data.faqs)
  .filter((faq) => faq.featured)
  .map((faq) => ({
    question: faq.question,
    answer: faq.answer,
  }))
---

<Layout title="Pricing (TODO)" description="TODO">
  <PricingSection as="header" level={1} fullWidth />
  <Testimonials />
  <HowItWorks />
  <FAQ faqs={faqs} />
  <ContactUs heading="Get in touch!" reversed>
    Have a question about our pricing? Get in touch using this form and we’ll
    respond as soon as we can – usually within 24 hours. If you're ready with
    your project details, feel free to explore our project planner for a
    clearer, more structured process.
  </ContactUs>
</Layout>
