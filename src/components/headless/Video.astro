---
import type { HTMLAttributes } from 'astro/types'

export type VideoModule = {
  default: string
}

export type VideoSource = Omit<HTMLAttributes<'source'>, 'src'> & {
  src: string | VideoModule | Promise<VideoModule>
}

type Props = Omit<HTMLAttributes<'video'>, 'src'> & {
  sources: VideoSource[]
  hash?: string
  lazy?: true
}

const { sources, hash = '0.001', lazy, ...props } = Astro.props

async function getSrc(source: VideoSource) {
  const src =
    typeof source.src === 'string'
      ? source.src
      : source.src instanceof Promise
        ? (await source.src)?.default
        : source.src?.default

  if (hash) {
    return `${src}#${hash}`
  }

  return src
}
---

<video {...props} data-lazy={lazy}>
  {
    sources.map(async (source) => {
      const { src: _, ...rest } = source
      const src = await getSrc(source)

      return (
        <source
          src={lazy ? undefined : src}
          data-src={lazy ? src : undefined}
          {...rest}
        />
      )
    })
  }
</video>

<script>
  window.addEventListener('load', () => {
    const videos =
      document.querySelectorAll<HTMLVideoElement>('video[data-lazy]')

    for (const video of videos) {
      const sources = video.querySelectorAll<HTMLSourceElement>('source')

      for (const source of sources) {
        source.src = source.dataset.src!
      }

      video.load()
    }
  })
</script>
