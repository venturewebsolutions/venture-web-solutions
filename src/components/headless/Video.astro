---
import type { HTMLAttributes } from 'astro/types'

type VideoModule = {
  default: string
}

type Props = Omit<HTMLAttributes<'video'>, 'src'> & {
  src: string | VideoModule | Promise<VideoModule>
  hash?: string
  lazy?: true
}

const { src: _, hash = '0.001', lazy, ...props } = Astro.props

let src =
  typeof Astro.props.src === 'string'
    ? Astro.props.src
    : Astro.props.src instanceof Promise
      ? (await Astro.props.src)?.default
      : Astro.props.src?.default

if (hash) {
  src += `#${hash}`
}
---

<video {...props} src={lazy ? undefined : src} data-src={src} data-lazy={lazy}>
  <slot />
</video>

<script>
  window.addEventListener('load', () => {
    const videos =
      document.querySelectorAll<HTMLVideoElement>('video[data-lazy]')

    for (const video of videos) {
      video.addEventListener('loadeddata', () => {
        video.setAttribute('data-loaded', '')
      })

      video.src = video.dataset.src!
    }
  })
</script>
