---
import FormField from '@/components/ui/FormField.astro'
import FormLabel from '@/components/ui/FormLabel.astro'
import type { AutocompleteValue } from '@/lib/types'
import FormHelper from './FormHelper.astro'

type Props = {
  id: string
  name: string
  type: astroHTML.JSX.HTMLInputTypeAttribute
  required?: boolean
  placeholder?: string
  autocomplete?: AutocompleteValue
  label?: string
  helper?: string
}

const { id, name, type, required, placeholder, autocomplete, label, helper } =
  Astro.props
---

<FormField>
  {
    label && (
      <FormLabel for={id} required={required}>
        {label}
      </FormLabel>
    )
  }
  <input
    id={id}
    name={name}
    type={type}
    required={required}
    placeholder={placeholder}
    autocomplete={autocomplete}
    class="form-input"
  />
  {helper && <FormHelper>{helper}</FormHelper>}
</FormField>
