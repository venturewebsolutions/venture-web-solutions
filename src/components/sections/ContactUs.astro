---
import Button from '@/components/ui/Button/Button.astro'
import ContactForm from '@/components/ui/ContactForm/ContactForm.astro'
import { url } from '@/lib/url'

type Props = {
  reversed?: boolean
  headingUnderline?: boolean
}

const { reversed, headingUnderline } = Astro.props
---

<section
  id="contact-us"
  class="container section"
  data-reversed={reversed || undefined}
>
  <div class="content-wrapper">
    <header class="header">
      <h2 class="h2">
        <slot name="heading">
          <span class="h2-italic">Still</span> have a question?
        </slot>
      </h2>
      {headingUnderline && <hr class="heading-underline" />}
    </header>

    <div class="content">
      <p>
        <slot name="paragraph">
          Okay, not a problem! For general enquires just reach out using this
          form and we’ll get back to you as soon as possible. If you're ready
          with your project details, feel free to explore our project planner
          for a clearer, more structured process.
        </slot>
      </p>

      <div class="email-link-wrapper">
        <p>Hate contact forms?</p>

        <a
          href="mailto:hello@venturewebsolutions.co.uk"
          class="email-link underline"
        >
          hello@venturewebsolutions.co.uk
        </a>
      </div>

      <Button href={url('/project-planner/')} arrow>
        Explore project planner
      </Button>
    </div>
  </div>

  <ContactForm class="form" />
</section>

<style lang="scss">
  @use 'functions' as *;
  @use 'mixins' as *;

  #contact-us {
    display: grid;
    gap: var(--spacing-5xl);
  }

  .heading-underline {
    border-top-width: 1px;
    max-width: rem(88px);
  }

  .content-wrapper {
    display: grid;
    gap: var(--spacing-m);
  }

  .content {
    display: grid;
    gap: var(--spacing-xl);
    justify-items: start;
  }

  .email-link-wrapper {
    display: flex;
    gap: var(--spacing-m);
    align-items: baseline;
    flex-wrap: wrap;
  }

  .email-link {
    @include font-link-md;
    color: var(--colour-text-contrast);
  }

  @media screen and (min-width: rem(1200px)) {
    #contact-us {
      grid-template-columns: minmax(0, rem(502px)) minmax(0, rem(679px));
      justify-content: space-between;
      align-items: start;

      &[data-reversed] {
        grid-template-columns: minmax(0, rem(679px)) minmax(0, rem(502px));

        .form {
          order: -1;
        }
      }
    }
  }
</style>
