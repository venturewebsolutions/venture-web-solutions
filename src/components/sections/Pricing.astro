---
import PricingCards from '@/components/ui/PricingCards.astro'
import type { HeadingLevel } from '@/lib/types'
import type { HTMLTag, Polymorphic } from 'astro/types'
import SectionHeader from '@/components/ui/SectionHeader.astro'
import { cn } from '@/lib/class-names'

type Props<Tag extends HTMLTag = 'section'> = Polymorphic<{
  as: Tag
}> & {
  heading?: string
  level?: HeadingLevel
  fullWidth?: boolean
}

const {
  as: Tag = 'section',
  heading = 'Choose your plan',
  level = 2,
  fullWidth = false,
  class: className,
  ...props
} = Astro.props as Props
---

<Tag id="pricing" class:list={cn('section container', className)} {...props}>
  <SectionHeader eyebrow="Pricing" level={level} class="header">
    {heading}
  </SectionHeader>

  <PricingCards
    level={Math.min(level + 1, 6) as HeadingLevel}
    fullWidth={fullWidth}
  />
</Tag>

<style lang="scss">
  @use 'functions' as *;
  @use 'mixins' as *;

  #pricing {
    display: grid;
    gap: var(--spacing-5xl);
  }

  .header {
    max-width: rem(567px);
  }
</style>
