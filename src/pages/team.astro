---
import BlogShowcaseCarousel from '@/components/sections/BlogShowcaseCarousel.astro'
import CallToAction from '@/components/sections/CallToAction.astro'
import MeetTheTeam from '@/components/sections/MeetTheTeam.astro'
import Layout from '@/layouts/Layout.astro'
import { getBlogPosts } from '@/lib/collections'
import take from 'lodash/take'

const posts = take(
  (await getBlogPosts()).filter((post) => post.data.featured),
  6,
)
---

<Layout
  title="Meet Our York Web Design Team | Venture Web Solutions"
  description="Meet the team behind Venture Web Solutions: web design and development specialists building websites for small businesses."
>
  <MeetTheTeam level={1} />
  <CallToAction
    heading="Ready to get started?"
    links={['start-your-project', 'get-in-touch']}
  >
    Thinking about a new website? Or just want to chat through some ideas?
    <br />
    <br />
    We’d love to hear from you — no pressure, no sales pitch.
  </CallToAction>
  <BlogShowcaseCarousel posts={posts} />
</Layout>
