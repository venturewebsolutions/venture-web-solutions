---
import type { HTMLAttributes } from 'astro/types'
import Heading from '@/components/headless/Heading.astro'
import { cn } from '@/lib/class-names'

type Props = HTMLAttributes<'section'> & {
  heading: string
  level: number
}

const { heading, level, class: className, ...props } = Astro.props
---

<section class:list={cn('card', className)} {...props}>
  <Heading level={level} class="h4">{heading}</Heading>
  <p><slot /></p>
</section>

<style lang="scss">
  @use 'functions' as *;
  @use 'mixins' as *;

  .card {
    display: grid;
    gap: var(--spacing-m);
    justify-items: center;
    align-content: start;
    background-color: var(--colour-surface-100);
    padding: var(--spacing-2xl) var(--spacing-xl-4xl);
    border-radius: var(--border-radius-m);
    text-align: center;
  }
</style>
