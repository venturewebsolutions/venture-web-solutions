---
import Eyebrow from '@/components/ui/Eyebrow.astro'
import { cn } from '@/lib/class-names'
import { take } from '@/lib/utils'
import type { HTMLAttributes } from 'astro/types'
import { Image } from 'astro:assets'

type Props = HTMLAttributes<'section'>

const { class: className, ...props } = Astro.props

const images = take(
  [
    {
      src: import('@/assets/images/about-1.jpg'),
    },
    {
      src: import('@/assets/images/about-2.jpg'),
    },
    {
      src: import('@/assets/images/about-3.jpg'),
    },
    {
      src: import('@/assets/images/about-4.jpg'),
    },
    {
      src: import('@/assets/images/about-5.jpg'),
    },
  ],
  25,
)
---

<section class:list={cn(className, 'section')} {...props}>
  <div class="container">
    <div class="header">
      <h1>
        <Eyebrow>About us</Eyebrow>
      </h1>

      <p class="h1">Hi, nice to meet you!</p>
    </div>
  </div>

  <div class="wheel-track">
    <div class="wheel" style={{ '--items': `${images.length}` }}>
      {
        images.map((image, index) => {
          return (
            <div
              class="wheel-item"
              style={{
                '--index': `${index}`,
              }}
            >
              <Image src={image.src} alt="" class="image" loading="eager" />
            </div>
          )
        })
      }
    </div>
  </div>
</section>

<style lang="scss">
  @use 'functions' as *;
  @use 'mixins' as *;

  .section {
    --padding-bottom: #{linear(var(--spacing-5xl), var(--spacing-8xl))};

    display: grid;
    gap: #{linear(var(--spacing-5xl), var(--spacing-8xl))};
    overflow: hidden;
  }

  .header {
    display: grid;
    gap: var(--spacing-2xs);
    text-align: center;
  }

  .wheel-track {
    --scale: #{linear(0.5, 1)};

    --item-width: calc(295px * var(--scale));
    --item-height: calc(303px * var(--scale));

    height: var(--item-height);
    position: relative;
  }

  .wheel {
    --radius: calc(1536px * var(--scale));

    // --angular-gap must be a multiple of 360deg to avoid gaps at the end
    --angular-gap: calc(360deg / var(--items));

    --translate-x: -50%;
    --translate-y: calc(var(--item-height) / -2);

    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(var(--translate-x)) translateY(var(--translate-y))
      rotateZ(0deg);

    z-index: -1;

    width: calc(var(--radius) * 2);
    height: calc(var(--radius) * 2);

    animation: spin 220s linear infinite;
  }

  .wheel-item {
    --index: 0;

    --left: calc(50% + 50% * sin(var(--index) * var(--angular-gap)));
    --top: calc(50% + 50% * cos(var(--index) * var(--angular-gap)));
    --rotation: calc(var(--index) * var(--angular-gap) * -1);

    position: absolute;

    left: var(--left);
    top: var(--top);
    transform: translateX(-50%) translateY(-50%) rotateZ(var(--rotation));

    width: var(--item-width);
    height: var(--item-height);
  }

  .image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--border-radius-m);
  }

  @keyframes spin {
    0% {
      transform: translateX(var(--translate-x)) translateY(var(--translate-y))
        rotateZ(0deg);
    }

    100% {
      transform: translateX(var(--translate-x)) translateY(var(--translate-y))
        rotateZ(360deg);
    }
  }
</style>
