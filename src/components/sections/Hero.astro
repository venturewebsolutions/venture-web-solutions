---
import Image from '@/components/headless/Image.astro'
import Video from '@/components/headless/Video.astro'
import Button from '@/components/ui/Button.astro'
import Eyebrow from '@/components/ui/Eyebrow.astro'
import Squiggle from '@/components/ui/Squiggle.astro'
import { cn } from '@/lib/class-names'
import { url } from '@/lib/url'
import type { HTMLAttributes } from 'astro/types'
import ImageSource from '../headless/ImageSource.astro'

type Props = HTMLAttributes<'section'>

const { class: className, ...props } = Astro.props
---

<section class:list={cn('hero section', className)} {...props}>
  <div class="hero-background">
    <picture>
      <ImageSource
        src={import('@/assets/images/hero-landscape.jpg')}
        widths={{
          min: 320,
          max: 2560,
          mobile: 412,
          desktop: 1440,
          step: 400,
        }}
        sizes="100vw"
        media="(orientation: landscape)"
      />

      <ImageSource
        src={import('@/assets/images/hero-portrait.jpg')}
        widths={{
          min: 320,
          max: 1440,
          mobile: 412,
          desktop: 1440,
          step: 400,
        }}
        sizes="100vw"
        media="(orientation: portrait)"
      />

      <Image
        src={import('@/assets/images/hero-portrait.jpg')}
        alt=""
        widths={{
          min: 320,
          max: 1440,
          mobile: 412,
          desktop: 1440,
          step: 400,
        }}
        sizes="100vw"
        class="hero-image"
        loading="eager"
      />
    </picture>

    <Video
      src={import('@/assets/videos/hero.mp4')}
      lazy
      autoplay
      playsinline
      muted
      loop
      class="hero-video"
    />
  </div>

  <div class="hero-content container">
    <Eyebrow>
      Hi, we’re Venture Web Solutions <span class="hand">👋</span>
    </Eyebrow>

    <h1 class="title h1">
      A web
      <span class="title-highlight">design agency</span>
      for small,
      <span class="squiggle-container">
        <span>ambitious</span>
        <span class="squiggle">
          <Squiggle animate />
        </span>
      </span> businesses
    </h1>
    <p class="subtitle">
      We build fast, great-looking websites with affordable pricing, 24/7
      support, and unlimited edits.
    </p>
    <div class="buttons">
      <Button variant="primary" href={url('/project-planner/')} arrow>
        Start a project
      </Button>
      <Button variant="secondary" href={url('/work/')} arrow>
        See our work
      </Button>
    </div>
  </div>
</section>

<style lang="scss">
  @use 'functions' as *;
  @use 'mixins' as *;

  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    text-align: center;
    background: linear-gradient(
      0deg,
      color-mix(in srgb, var(--colour-surface-base) 75%, transparent),
      color-mix(in srgb, var(--colour-surface-base) 75%, transparent)
    );
  }

  .hero-background {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    z-index: -1;

    &::after {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(
        180deg,
        color-mix(in srgb, var(--colour-surface-base) 0%, transparent),
        color-mix(in srgb, var(--colour-surface-base) 100%, transparent)
      );
    }
  }

  .hero-image {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-video {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: cover;

    &:not([data-loaded]) {
      display: none;
    }
  }

  .hero-content {
    display: grid;
  }

  .hand {
    --max-rotation: 28deg;
    --max-scale: 1.3;

    display: inline-block;
    transform-origin: 70% 70%;
    animation: wave 1s ease-in-out 0.8s 1 forwards;
  }

  @keyframes wave {
    0% {
      transform: rotate(0deg) scale(1) translateY(-2px);
    }
    15% {
      transform: rotate(var(--max-rotation)) scale(var(--max-scale))
        translateY(-2px);
    }
    30% {
      transform: rotate(calc(var(--max-rotation) * -8 / 14))
        scale(var(--max-scale)) translateY(-2px);
    }
    45% {
      transform: rotate(var(--max-rotation)) scale(var(--max-scale))
        translateY(-2px);
    }
    60% {
      transform: rotate(calc(var(--max-rotation) * -4 / 14))
        scale(var(--max-scale)) translateY(-2px);
    }
    75% {
      transform: rotate(calc(var(--max-rotation) * 10 / 14))
        scale(var(--max-scale)) translateY(-2px);
    }
    100% {
      transform: rotate(0deg) scale(1);
    }
  }

  .title {
    max-width: #{em(745px, 72px)};
    margin-top: var(--spacing-xl);
  }

  .title-highlight {
    color: var(--colour-primary);
  }

  .subtitle {
    max-width: #{em(419px, 16px)};
    margin-inline: auto;
    margin-top: var(--spacing-xl);
  }

  .squiggle-container {
    position: relative;
  }

  .squiggle {
    position: absolute;
    bottom: -0.15em;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    pointer-events: none;
    color: var(--colour-primary);
  }

  .buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    column-gap: #{linear(var(--spacing-m), var(--spacing-xl))};
    row-gap: var(--spacing-m);
    margin-top: var(--spacing-4xl);
  }
</style>
