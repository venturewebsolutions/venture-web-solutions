---
import PortfolioShowcase from '@/components/sections/PortfolioShowcase.astro'
import Testimonials from '@/components/sections/Testimonials.astro'
import Layout from '@/layouts/Layout.astro'
import { getTestimonials, getWork } from '@/lib/collections'

const projects = await getWork()
const testimonials = await getTestimonials()
---

<Layout
  title="Web Design Portfolio | Venture Web Solutions"
  description="See how we've helped small businesses across the UK launch and grow online. Browse our portfolio of custom, hand-coded websites built for clients in hospitality, home care, pet grooming, and more."
>
  <PortfolioShowcase projects={projects} />
  <Testimonials testimonials={testimonials} />
</Layout>
