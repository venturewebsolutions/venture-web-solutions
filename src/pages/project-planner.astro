---
import HowItWorks from '@/components/sections/HowItWorks.astro'
import ProjectPlannerSection from '@/components/sections/ProjectPlanner.astro'
import Layout from '@/layouts/Layout.astro'
---

<Layout title="Project Planner (TODO)" description="TODO">
  <ProjectPlannerSection />

  <HowItWorks
    id="process"
    eyebrow="Process"
    heading="What happens next?"
    steps={[
      {
        heading: 'We’ll be in touch',
        text: 'We’ll respond within 24 hours to arrange a quick discovery call.',
      },
      {
        heading: 'Discovery & Planning',
        text: 'We’ll chat about your business, your goals, and make sure we’re a good fit. If everyone’s happy, we’ll send over a contract.',
      },
      {
        heading: 'Design',
        text: 'We’ll design your website and handle the copy. You’ll only move forward once you’re genuinely happy.',
      },
      {
        heading: 'Development & Launch',
        text: 'We’ll hand-code your site, show you a preview, and put it live once you give the thumbs up.',
      },
      {
        heading: 'Ongoing support',
        text: 'Once your site is live, we’re always here when you need us.',
      },
    ]}
  />
</Layout>

<style lang="scss">
  @use 'functions' as *;
  @use 'mixins' as *;

  .section {
    display: grid;
    align-items: center;
    row-gap: var(--spacing-5xl);
  }

  .video-wrapper {
    border-radius: var(--border-radius-l);
    overflow: hidden;
    position: relative;
    order: 1;
  }

  @media screen and (min-width: rem(768px)) {
    .section {
      grid-template-columns: repeat(2, auto);
      column-gap: var(--spacing-5xl);
    }

    .video-wrapper {
      max-width: 453px;
      order: unset;
    }
  }

  .video {
    aspect-ratio: 453/760;
    object-fit: cover;
  }

  .video-caption {
    @include font(body-medium);
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    color: var(--colour-text-contrast);
    padding: var(--spacing-s) var(--spacing-2xl);
    background-color: color-mix(
      in srgb,
      var(--colour-surface-base) 75%,
      transparent
    );
    text-align: center;
  }

  .stepper {
    max-width: rem(648px);
  }

  .content {
    display: grid;
    gap: var(--spacing-3xl);
  }

  .step-info {
    display: grid;
    gap: var(--spacing-m);
  }

  .progress-bar {
    --progress: calc(var(--stepper-current-step) / 3);
  }

  .step-info-text {
    @include font(body-medium);
    color: var(--colour-text-contrast);
  }

  .step {
    display: grid;
    gap: var(--spacing-2xl);
  }

  .step-header {
    display: grid;
    gap: var(--spacing-m);
  }

  .step-form {
    display: grid;
    gap: var(--spacing-m);
  }

  .buttons {
    display: flex;
    align-items: center;
    gap: var(--spacing-m);
  }

  .stepper[data-first-step] {
    .previous-step-button {
      display: none;
    }
  }

  .stepper[data-last-step] {
    .next-step-button {
      display: none;
    }
  }

  .stepper:not([data-last-step]) {
    .submit-button {
      display: none;
    }
  }

  .step:not([data-current-step]) {
    display: none;
  }
</style>
