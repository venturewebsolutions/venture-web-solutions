---
import { Icon } from 'astro-icon/components'
---

<div class="read-time">
  <Icon name="clock" class="icon" />
  <p><slot /></p>
</div>

<style lang="scss">
  @use 'functions' as *;
  @use 'mixins' as *;

  .read-time {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--spacing-2xs);
  }

  .icon {
    --size: #{rem(16px)};
  }
</style>
