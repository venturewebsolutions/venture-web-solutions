---
import { cn } from '@/lib/class-names'
import type { HTMLTag, Polymorphic } from 'astro/types'

type Props<Tag extends HTMLTag = 'p'> = Polymorphic<{
  as: Tag
}>

const { as: Tag = 'p', class: className, ...props } = Astro.props as Props
---

<Tag class:list={cn('eyebrow', className)} {...props}><slot /></Tag>

<style lang="scss">
  @use 'functions' as *;
  @use 'mixins' as *;

  .eyebrow {
    @include font(caption);

    &::before {
      --bullet-size: 0.5em;

      content: '';
      display: inline-block;
      width: var(--bullet-size);
      height: var(--bullet-size);
      border-radius: 50%;
      vertical-align: middle;
      margin-right: var(--spacing-xs);
      margin-top: calc(-1 * var(--bullet-size) / 2);
      background-color: currentColor;
    }
  }
</style>
